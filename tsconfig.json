{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",

    "declaration": true,
    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "outDir": "dist",
    "rootDir": "src"
  },

  "include": [
    "src/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "cdk.out",
    "test",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}